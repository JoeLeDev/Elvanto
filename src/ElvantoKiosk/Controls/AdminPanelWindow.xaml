<Window x:Class="ElvantoKiosk.Controls.AdminPanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Administration — ICC Kiosk"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        Width="920" Height="680"
        Background="#0F172A">

    <Border Background="#1E293B" CornerRadius="16" Margin="16" Padding="24">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.5" Color="#000000" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="Panneau administrateur"
                           Foreground="#F8FAFC" FontSize="26" FontWeight="Bold" />
                <TextBlock x:Name="VersionText"
                           Foreground="#94A3B8" FontSize="14" Margin="0,6,0,0" />
            </StackPanel>

            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                <TabItem Header="Système">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                        <StackPanel MaxWidth="820">
                            <TextBlock Text="État de la connexion"
                                       Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Teste l'accès Internet et l'URL du premier formulaire Notion."
                                       Foreground="#94A3B8" FontSize="14" Margin="0,6,0,12" TextWrapping="Wrap" />
                            <TextBlock x:Name="ConnectionStatusText"
                                       Foreground="#CBD5E1" FontSize="15" Margin="0,0,0,12" TextWrapping="Wrap" />
                            <Button Content="Tester la connexion" Click="TestConnection_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left" MinWidth="220" MinHeight="48" Margin="0,0,0,24" />

                            <TextBlock Text="Rechargement à chaud"
                                       Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Relit config.json et met à jour l'écran sans redémarrer. Raccourci : Ctrl+Maj+R."
                                       Foreground="#94A3B8" FontSize="14" Margin="0,6,0,12" TextWrapping="Wrap" />
                            <Button Content="Recharger la configuration" Click="ReloadConfig_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#334155" HorizontalAlignment="Left"
                                    MinWidth="220" MinHeight="48" Margin="0,0,0,24" />

                            <TextBlock Text="Quitter la borne"
                                       Foreground="#F8FAFC" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="Ferme complètement l'application kiosque."
                                       Foreground="#94A3B8" FontSize="14" Margin="0,6,0,12" TextWrapping="Wrap" />
                            <Button Content="Quitter l'application" Click="QuitApp_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    Background="#991B1B" HorizontalAlignment="Left"
                                    MinWidth="220" MinHeight="48" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Journal">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Button Grid.Row="0" Content="Actualiser" Click="RefreshLogs_Click"
                                Style="{StaticResource PrimaryButton}" Background="#334155"
                                HorizontalAlignment="Left" MinWidth="140" MinHeight="44" Margin="0,0,0,12" />
                        <TextBox x:Name="LogTextBox" Grid.Row="1"
                                 IsReadOnly="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#0F172A" Foreground="#CBD5E1"
                                 BorderBrush="#334155" FontFamily="Consolas" FontSize="12"
                                 Padding="12" />
                    </Grid>
                </TabItem>

                <TabItem Header="Configuration">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ConfigEditorPanel" MaxWidth="820" />
                        </ScrollViewer>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,0">
                            <TextBlock x:Name="SaveStatusText" Foreground="#86EFAC"
                                       VerticalAlignment="Center" Margin="0,0,16,0" Visibility="Collapsed" />
                            <Button Content="Enregistrer config.json" Click="SaveConfig_Click"
                                    Style="{StaticResource PrimaryButton}"
                                    MinWidth="220" MinHeight="48" />
                        </StackPanel>
                    </Grid>
                </TabItem>
            </TabControl>

            <Button Grid.Row="2" Content="Fermer" Click="Close_Click"
                    Style="{StaticResource PrimaryButton}" Background="#334155"
                    HorizontalAlignment="Right" MinWidth="140" MinHeight="48" Margin="0,16,0,0" />
        </Grid>
    </Border>
</Window>
