<UserControl x:Class="ElvantoKiosk.Controls.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F8FAFC">

    <Grid Margin="28,24,28,24">
        <!-- Fond décoratif très léger -->
        <Ellipse Width="480" Height="480" Opacity="0.045"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-160,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#2563EB" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="360" Height="360" Opacity="0.04"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-120,0,0,-80">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#7C3AED" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Panel.ZIndex="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="180" />
                <RowDefinition Height="1.65*" MinHeight="280" />
            </Grid.RowDefinitions>

            <!-- Bandeau logo + présentation -->
            <Border Grid.Row="0" CornerRadius="20" Margin="0,0,0,16"
                    BorderBrush="#E2E8F0" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFF" Offset="0" />
                        <GradientStop Color="#F8FAFC" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.07" Color="#0F172A" />
                </Border.Effect>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="48,36" MaxWidth="960">
                    <Border x:Name="LogoFrame" Background="Transparent" Padding="0"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                        <Image x:Name="LogoImage" MaxHeight="128" Stretch="Uniform"
                               HorizontalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                    </Border>

                    <TextBlock x:Name="OrgNameText"
                               Foreground="#0F172A"
                               FontSize="34" FontWeight="Bold"
                               HorizontalAlignment="Center" TextAlignment="Center" />

                    <TextBlock Text="ACCUEIL"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="12" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />

                    <TextBlock x:Name="WelcomeTitleText"
                               Foreground="#0F172A"
                               FontSize="32" FontWeight="Bold"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,6,0,0" />

                    <Border Height="1" Width="64" Background="#E2E8F0"
                            HorizontalAlignment="Center" Margin="0,16,0,0" />

                    <TextBlock x:Name="WelcomeMessageText"
                               Foreground="#64748B"
                               FontSize="18" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,16,0,0"
                               TextWrapping="Wrap" LineHeight="28" MaxWidth="680" />
                </StackPanel>
            </Border>

            <UniformGrid x:Name="FormsPanel" Grid.Row="1"
                         Rows="1" Columns="4"
                         VerticalAlignment="Stretch" />

            <TextBlock x:Name="NoFormsText" Grid.Row="1"
                       Text="Aucun formulaire configuré. Modifiez config.json."
                       Foreground="#64748B"
                       FontSize="20" HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
        </Grid>
    </Grid>
</UserControl>
