<Window x:Class="ElvantoKiosk.Controls.PinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Administration"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        Width="420">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="16" Padding="28">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="#000000" />
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="Administration"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Saisissez le code PIN pour accéder au panneau administrateur."
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="15" Margin="0,8,0,20" TextWrapping="Wrap"
                       HorizontalAlignment="Center" TextAlignment="Center" />

            <!-- Affichage du PIN (points) -->
            <Border Background="#0F172A" CornerRadius="10" Padding="16,12" Margin="0,0,0,16">
                <TextBlock x:Name="PinDisplay"
                           Text=""
                           Foreground="{StaticResource TextBrush}"
                           FontSize="36" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           MinHeight="44" />
            </Border>

            <TextBlock x:Name="ErrorText" Text="Code PIN incorrect."
                       Foreground="#F87171" FontSize="14"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,8" Visibility="Collapsed" />

            <!-- Clavier numérique tactile -->
            <UniformGrid Rows="4" Columns="3" HorizontalAlignment="Center">
                <Button Content="1" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="1" />
                <Button Content="2" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="2" />
                <Button Content="3" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="3" />
                <Button Content="4" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="4" />
                <Button Content="5" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="5" />
                <Button Content="6" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="6" />
                <Button Content="7" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="7" />
                <Button Content="8" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="8" />
                <Button Content="9" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="9" />
                <Button Content="C" Style="{StaticResource PinKeyButton}" Click="Clear_Click"
                        FontSize="22" ToolTip="Effacer" />
                <Button Content="0" Style="{StaticResource PinKeyButton}" Click="Digit_Click" Tag="0" />
                <Button Content="&#9003;" Style="{StaticResource PinKeyButton}" Click="Backspace_Click"
                        FontSize="22" ToolTip="Retour arrière" />
            </UniformGrid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Content="Annuler" Click="Cancel_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="#334155" Margin="0,0,12,0"
                        MinWidth="140" MinHeight="52" FontSize="18" />
                <Button Content="Valider" Click="Ok_Click"
                        Style="{StaticResource PrimaryButton}"
                        MinWidth="140" MinHeight="52" FontSize="18" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
