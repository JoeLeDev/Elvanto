<Window x:Class="ElvantoKiosk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:controls="clr-namespace:ElvantoKiosk.Controls"
        Title="Elvanto Kiosk"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Topmost="True"
        Background="#FFFFFF"
        UseLayoutRounding="True">

    <Grid>
        <!-- Écran de veille (au lancement et après inactivité) -->
        <controls:ScreensaverView x:Name="Screensaver" Visibility="Collapsed" Panel.ZIndex="200" />

        <!-- Page d'accueil (fond blanc, 4 boutons en ligne) -->
        <controls:HomeView x:Name="Home" Visibility="Collapsed" />

        <!-- Vue formulaire : barres hors WebView2 (sinon Notion les recouvre) -->
        <Grid x:Name="FormContainer" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="72" />
                <RowDefinition Height="*" />
                <RowDefinition Height="72" />
            </Grid.RowDefinitions>

            <!-- Barre supérieure : titre du formulaire + aide à la saisie e-mail -->
            <Grid x:Name="TopBar" Grid.Row="0" Background="#0B1120">
                <TextBlock x:Name="FormTitleText"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="20" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Margin="24,0" TextTrimming="CharacterEllipsis" />

                <StackPanel x:Name="EmailHelperBar"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,16,0"
                            Visibility="Collapsed">
                    <Button Content="@" Style="{StaticResource EmailHelperButton}" Focusable="False"
                            FontWeight="Bold" Click="EmailHelper_At_Click" />
                    <Button Content="@gmail.com" Style="{StaticResource EmailHelperButton}" Focusable="False"
                            Tag="@gmail.com" Click="EmailHelper_Domain_Click" />
                    <Button Content="@hotmail.fr" Style="{StaticResource EmailHelperButton}" Focusable="False"
                            Tag="@hotmail.fr" Click="EmailHelper_Domain_Click" />
                    <Button Content="@outlook.fr" Style="{StaticResource EmailHelperButton}" Focusable="False"
                            Tag="@outlook.fr" Click="EmailHelper_Domain_Click" />
                    <Button Content="@orange.fr" Style="{StaticResource EmailHelperButton}" Focusable="False"
                            Tag="@orange.fr" Click="EmailHelper_Domain_Click" />
                    <Button Content="@yahoo.fr" Style="{StaticResource EmailHelperButton}" Focusable="False"
                            Tag="@yahoo.fr" Click="EmailHelper_Domain_Click" />
                </StackPanel>
            </Grid>

            <!-- Zone Notion (WebView2 uniquement ici — ne couvre pas les barres) -->
            <Grid Grid.Row="1" Background="#FFFFFF">
                <wv2:WebView2 x:Name="Web" Focusable="True" />
                <Border x:Name="FormLoadingPlaceholder" Background="#0B1120" Visibility="Collapsed">
                    <TextBlock Text="Chargement…" Foreground="{StaticResource TextBrush}"
                               FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Grid>

            <!-- Barre inférieure -->
            <Grid x:Name="BottomBar" Grid.Row="2" Background="#0B1120">
                <Button x:Name="FormHomeButton"
                        Style="{StaticResource FormHomeButton}"
                        Content="&#8592;  Revenir à l'accueil"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="20,0,0,0" Click="HomeButton_Click" />
                <Button x:Name="FormAdminExitButton"
                        Style="{StaticResource AdminExitButton}"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,12,0" Click="AdminExitButton_Click"
                        ToolTip="Administration"
                        Content="&#128274;" FontSize="14" />
            </Grid>
        </Grid>

        <!-- Overlay d'erreur réseau -->
        <Grid x:Name="ErrorOverlay" Background="{StaticResource BackgroundBrush}" Visibility="Collapsed">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="700">
                <TextBlock Text="&#9888;" FontSize="72" HorizontalAlignment="Center"
                           Foreground="#FBBF24" Margin="0,0,0,20" />
                <TextBlock Text="Connexion indisponible"
                           Foreground="{StaticResource TextBrush}"
                           FontSize="34" FontWeight="Bold"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="ErrorDetailText"
                           Text="Le formulaire n'a pas pu être chargé. Vérifiez la connexion Internet."
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="20" TextAlignment="Center" TextWrapping="Wrap"
                           HorizontalAlignment="Center" Margin="0,16,0,32" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Réessayer" Style="{StaticResource PrimaryButton}"
                            Click="Retry_Click" Margin="0,0,12,0" />
                    <Button Content="Retour à l'accueil" Style="{StaticResource PrimaryButton}"
                            Background="#334155" Click="HomeButton_Click" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Overlay remerciement après soumission -->
        <Grid x:Name="ThankYouOverlay" Visibility="Collapsed" Panel.ZIndex="95"
              Background="#CC0F172A">
            <Border Background="#FFFFFF" CornerRadius="24" Padding="48,40"
                    MaxWidth="560" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="40" ShadowDepth="0" Opacity="0.2" Color="#000000" />
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#10003;" FontSize="56" Foreground="#22C55E"
                               HorizontalAlignment="Center" Margin="0,0,0,16" />
                    <TextBlock x:Name="ThankYouMessageText"
                               Text="Merci ! Retour à l'accueil…"
                               Foreground="#0F172A" FontSize="28" FontWeight="Bold"
                               TextAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock x:Name="ThankYouCountdownText"
                               Foreground="#64748B" FontSize="18"
                               HorizontalAlignment="Center" Margin="0,14,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Bouton admin sur la page d'accueil uniquement -->
        <Button x:Name="AdminExitButton"
                Style="{StaticResource AdminExitButton}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,10,10"
                Click="AdminExitButton_Click"
                ToolTip="Administration"
                Content="&#128274;" FontSize="14" />
    </Grid>
</Window>
