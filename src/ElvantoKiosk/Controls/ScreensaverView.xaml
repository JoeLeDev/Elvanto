<UserControl x:Class="ElvantoKiosk.Controls.ScreensaverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A1028"
             Cursor="Hand">

    <Grid MouseDown="OnScreenTouched" TouchDown="OnScreenTouched">
        <!-- Fond : image si fournie, sinon dégradé proche de la maquette -->
        <Image x:Name="BackgroundImage" Stretch="UniformToFill" Visibility="Collapsed" />
        <Grid x:Name="BackgroundFallback">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                    <GradientStop Color="#0B1E3D" Offset="0" />
                    <GradientStop Color="#1A3A5C" Offset="0.35" />
                    <GradientStop Color="#2D1B4E" Offset="0.7" />
                    <GradientStop Color="#1A1040" Offset="1" />
                </LinearGradientBrush>
            </Grid.Background>
            <Rectangle Opacity="0.18">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#22D3EE" Offset="0" />
                        <GradientStop Color="Transparent" Offset="0.5" />
                        <GradientStop Color="#F472B6" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>

        <Grid Margin="40,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- En-tête : logo + date/heure -->
            <Grid Grid.Row="0">
                <Image x:Name="LogoImage"
                       MaxHeight="200"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Visibility="Collapsed" />

                <TextBlock x:Name="OrgNameText"
                           Text="Impact Centre Chrétien"
                           Foreground="#F8FAFC"
                           FontSize="28" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Visibility="Collapsed" />

                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,0,0">
                    <TextBlock x:Name="DateText"
                               Foreground="#F8FAFC"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                    <TextBlock x:Name="TimeText"
                               Foreground="#F8FAFC"
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,2,0,0" />
                </StackPanel>
            </Grid>

            <!-- Titre graphique « PRISE DE RENDEZ-VOUS » -->
            <Grid Grid.Row="1" VerticalAlignment="Center">
                <Image x:Name="TitleImage"
                       MaxWidth="820"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="Collapsed" />
                <TextBlock x:Name="TitleFallbackText"
                           Text="PRISE DE RENDEZ-VOUS"
                           Foreground="#F8FAFC"
                           FontSize="52" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Visibility="Collapsed" />
            </Grid>

            <!-- Invitation tactile -->
            <TextBlock x:Name="PromptText"
                       Grid.Row="2"
                       Text="TOUCHEZ L'ÉCRAN POUR COMMENCER"
                       Foreground="#F8FAFC"
                       FontSize="14" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12" />
        </Grid>
    </Grid>
</UserControl>
