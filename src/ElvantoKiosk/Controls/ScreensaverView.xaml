<UserControl x:Class="ElvantoKiosk.Controls.ScreensaverView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0A0618"
             Cursor="Hand">

    <Grid MouseDown="OnScreenTouched" TouchDown="OnScreenTouched">
        <!-- Dégradé violet -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#1E1538" Offset="0" />
                <GradientStop Color="#120C28" Offset="0.55" />
                <GradientStop Color="#0A0618" Offset="1" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Orbes décoratifs -->
        <Ellipse Width="900" Height="900" Opacity="0.12"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-350,-280,0,0">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#7C3AED" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>
        <Ellipse Width="700" Height="700" Opacity="0.10"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-250,-200">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#2563EB" Offset="0" />
                    <GradientStop Color="Transparent" Offset="1" />
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <!-- Logo -->
            <Border x:Name="LogoFrame" Background="Transparent" Padding="0,0,0,8"
                    HorizontalAlignment="Center" Visibility="Collapsed">
                <Image x:Name="LogoImage" MaxHeight="120" Stretch="Uniform"
                       HorizontalAlignment="Center" />
            </Border>

            <TextBlock x:Name="OrgNameText"
                       Text="Impact Centre Chrétien"
                       Foreground="#F8FAFC"
                       FontSize="42" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextAlignment="Center" Margin="0,8,0,0" />

            <TextBlock x:Name="SubtitleText"
                       Text="KIOSQUE DE PRISE DE RENDEZ-VOUS"
                       Foreground="#C4B5FD"
                       FontSize="14" FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" />

            <!-- Horloge -->
            <StackPanel HorizontalAlignment="Center" Margin="0,48,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="HoursText" Text="00"
                               Foreground="#F8FAFC" FontSize="120" FontWeight="Light"
                               FontFamily="Segoe UI Light" />
                    <TextBlock Text=":" Foreground="#FBBF24" FontSize="120" FontWeight="Light"
                               FontFamily="Segoe UI Light" Margin="4,0" />
                    <TextBlock x:Name="MinutesText" Text="00"
                               Foreground="#F8FAFC" FontSize="120" FontWeight="Light"
                               FontFamily="Segoe UI Light" />
                    <TextBlock x:Name="SecondsText" Text="00"
                               Foreground="#A78BFA" FontSize="36" FontWeight="Light"
                               FontFamily="Segoe UI Light"
                               VerticalAlignment="Top" Margin="12,18,0,0" />
                </StackPanel>
                <TextBlock x:Name="DateText"
                           Foreground="#A78BFA"
                           FontSize="15" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>

            <!-- Invite tactile -->
            <StackPanel HorizontalAlignment="Center" Margin="0,56,0,0">
                <Grid Width="48" Height="48" HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Ellipse Width="48" Height="48" Stroke="#FBBF24" StrokeThickness="2" Opacity="0.5" />
                    <Ellipse x:Name="PulseDot" Width="14" Height="14" Fill="#FBBF24"
                             HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
                <TextBlock x:Name="PromptText"
                           Text="TOUCHEZ L'ÉCRAN POUR COMMENCER"
                           Foreground="#C4B5FD"
                           FontSize="13" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
