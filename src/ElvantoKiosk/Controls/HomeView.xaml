<UserControl x:Class="ElvantoKiosk.Controls.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <!-- Fond décoratif (couleurs inspirées du logo ICC) -->
        <Grid Background="#0B1120">
            <Ellipse Width="720" Height="720" Fill="#1E40AF" Opacity="0.14"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-260,-200,0,0" />
            <Ellipse Width="560" Height="560" Fill="#7C3AED" Opacity="0.10"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-180,-120" />
            <Ellipse Width="420" Height="420" Fill="#CA8A04" Opacity="0.07"
                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-80,0,0" />
        </Grid>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,40,0,0">
                <Border x:Name="LogoFrame" Background="#141C2E" CornerRadius="20" Padding="24,16"
                        BorderBrush="#2A3A55" BorderThickness="1" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                    <Image x:Name="LogoImage" MaxHeight="130" Stretch="Uniform"
                           HorizontalAlignment="Center" Visibility="Collapsed" />
                </Border>
                <TextBlock x:Name="OrgNameText"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="18" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,14,0,0" />
            </StackPanel>

            <!-- Corps -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="48,24,48,24" MaxWidth="1100">

                <Border Background="#141C2E" CornerRadius="16" Padding="28,20"
                        BorderBrush="#2A3A55" BorderThickness="1"
                        HorizontalAlignment="Center" Margin="0,0,0,36" MaxWidth="820">
                    <StackPanel>
                        <TextBlock Text="ACCUEIL"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="WelcomeTitleText"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="48" FontWeight="Bold"
                                   HorizontalAlignment="Center" TextAlignment="Center"
                                   Margin="0,8,0,0" />
                        <TextBlock x:Name="WelcomeMessageText"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   FontSize="20" HorizontalAlignment="Center"
                                   TextAlignment="Center" Margin="0,12,0,0"
                                   TextWrapping="Wrap" LineHeight="28" />
                    </StackPanel>
                </Border>

                <ItemsControl x:Name="FormsList" HorizontalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel HorizontalAlignment="Center" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource FormCardButton}"
                                    Click="FormButton_Click"
                                    Tag="{Binding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Width="40" Height="4" CornerRadius="2"
                                            Background="{StaticResource AccentBrush}"
                                            HorizontalAlignment="Left" Margin="0,0,0,14" />

                                    <TextBlock Grid.Row="1" Text="{Binding Title}"
                                               FontSize="24" FontWeight="Bold"
                                               Foreground="{StaticResource TextBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Grid.Row="2" Text="{Binding Description}"
                                               FontSize="15"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap" Margin="0,10,0,0"
                                               VerticalAlignment="Top" LineHeight="22" />

                                    <Border Grid.Row="3" Width="36" Height="36" CornerRadius="18"
                                            Background="#253049" HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom" Margin="0,12,0,0">
                                        <TextBlock Text="&#8594;" FontSize="18" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock x:Name="NoFormsText"
                           Text="Aucun formulaire configuré. Modifiez config.json."
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="20" HorizontalAlignment="Center"
                           Visibility="Collapsed" Margin="0,20,0,0" />
            </StackPanel>

            <!-- Pied de page -->
            <Border Grid.Row="2" BorderBrush="#1E293B" BorderThickness="0,1,0,0"
                    Margin="48,0" Padding="0,14,0,18">
                <TextBlock x:Name="FooterText"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="13" Opacity="0.7"
                           HorizontalAlignment="Center" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
